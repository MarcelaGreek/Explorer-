# Copy this file to .env.local and fill in real values. Do NOT put real keys here.
# .env.example is committed as documentation; .env.local is gitignored. MUST BE env.local !!!!!!!!!IMPORTANT

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
OPENAI_API_KEY=your-openai-api-key

# Optional. Server-only. Falls back to NEXT_PUBLIC_SUPABASE_ANON_KEY if empty.
SUPABASE_SERVER_KEY=
